if SHIELD_MACROKNOB

config ZMK_KEYBOARD_NAME
    default "MacroKnob Aurora Sofle"

config ZMK_SPLIT
    default y

config ZMK_SPLIT_ROLE_CENTRAL
    default y

# Aurora Sofle is a 2-half split keyboard, both halves connect to this dongle.
config ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS
    default 2

# 2 split peripherals + 5 host profiles.
config BT_MAX_CONN
    default 7

# Keep paired device slots aligned with max connections.
config BT_MAX_PAIRED
    default 7

endif # SHIELD_MACROKNOB
